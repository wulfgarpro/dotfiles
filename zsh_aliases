#-Aliases

z() {
    nohup zathura "$@" >/dev/null 2>&1 &
}

## Programming
alias gdt="git difftool"
alias gl="git log --color --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit"
alias gmt="git mergetool"
alias gmv="git mv"
alias gpl="git pull"
alias gs="git stash"
alias gsp="git stash pop"
alias grbc="git rebase --continue"
alias lg="lazygit"
alias mdf="meld --diff "

## System
# alias nvim="/opt/nvim.appimage" # Nightly
alias n="nvim"
alias sudo="sudo " # Space allows `sudo` aliases
alias readme="glow -p README.md"
alias h="hexyl "
alias tree="eza --tree --icons"
alias y="yazi"
alias cat="bat -p --theme tokyonight_storm"
alias diff="difft"
alias top="htop"
pmc() {
  local orphans
  orphans=$(pacman -Qtdq) || { echo "No orphan packages to remove."; return 0; }
  sudo pacman -Rsnc $orphans
}
alias ipy="ipython"
### Tmux
alias tmn="tmux new -s "
alias tml="tmux list-sessions"
alias tma="tmux attach "
### Sway
alias ti="${XDG_CONFIG_HOME:-$HOME/.config}/sway/toggle-idle.sh"
alias sbw="set-bing-wallpaper.sh"
alias ls="lsd"

# Navigation
alias code="cd $HOME/code"
alias work="cd $HOME/code/work"
